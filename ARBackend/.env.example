# Ollama settings (used by ARBackend / /chat)
# If you use the included docker-compose.yml with the ollama service, keep these defaults.

OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=llama3.2

# FastAPI listens on 8000 inside the container (see Dockerfile / compose)
# If you change ports, update Unity accordingly.
